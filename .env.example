# Copy to .env and fill in real values. NEVER commit .env.

# --- Core ---
# Required when DEBUG=False. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# "True" only on a local dev machine. Anything else (or unset) means production mode.
DEBUG=False
# Comma-separated hostnames the API may be served from.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Email (Gmail SMTP for meeting reminders) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
ADMIN_EMAIL=

# --- Rate limits (leave unset in production for the strict defaults) ---
# Raise these on a dev machine so Playwright E2E runs aren't throttled.
#THROTTLE_ANON=30/min
#THROTTLE_USER=300/min
#THROTTLE_LOGIN=5/min
#THROTTLE_REFRESH=30/min

# --- Documents ---
# Max upload size in bytes (default 10485760 = 10 MB).
DOCUMENT_MAX_UPLOAD_SIZE=10485760

# --- Cloudflare R2 storage (production only; leave empty to use local files) ---
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Copy to .env and fill in real values. NEVER commit .env.

# --- Core ---
# Deployment profile: desktop | cloud | hybrid (default: cloud). Derives
# per-mode defaults for the database, media backend, email transport, and
# scheduler; every individual var below still overrides its mode default.
#   desktop -> local SQLite, local file storage, console email, no cloud creds needed
#   cloud   -> Neon/Postgres via DATABASE_URL, R2 storage, real SMTP email
#   hybrid  -> like desktop today, reserved for future local+cloud sync
DEPLOYMENT_MODE=cloud
# Desktop/hybrid only: overrides the per-user data directory that holds the
# SQLite DB, media, logs, backups, and temp files (default: the OS-standard
# per-user app-data path, e.g. %APPDATA%/EduCare on Windows). Useful for
# pointing a local test run at a scratch directory instead of the real one.
#DESKTOP_DATA_DIR=
# Required when DEBUG=False. Never reuse a value across environments.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# "True" only on a local dev machine (enables Swagger/ReDoc, relaxes HTTPS-only
# security headers). Anything else, or unset, means production hardening is on.
DEBUG=False
# Comma-separated hostnames the API may be served from (Django's ALLOWED_HOSTS).
# Use the exact production hostname — never a wildcard like *.onrender.com.
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated frontend origins allowed by CORS. Must match the URL the
# browser actually loads the SPA from (protocol + host + port).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
# External PostgreSQL connection string (Neon in production) — keep
# ?sslmode=require at the end. Leave unset in dev/desktop to fall back to the
# local db.sqlite3 file automatically.
DATABASE_URL=

# --- Auth ---
# Path the httpOnly refresh cookie is scoped to. Must match the URL the
# browser sees when calling the token endpoints. Production behind the
# static-site /api proxy needs /api/token; leave unset in dev for /token.
REFRESH_COOKIE_PATH=

# --- Email (Gmail SMTP; used to send meeting reminder notifications) ---
# Transport is auto-selected by DEPLOYMENT_MODE: cloud -> real SMTP,
# desktop/hybrid -> prints emails to the console instead (unless
# EMAIL_HOST_USER is set, which opts a local install into real SMTP too).
# Only set EMAIL_BACKEND explicitly to override that default, e.g.:
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#EMAIL_BACKEND=
# Gmail address the reminder emails are sent FROM (also used as the default
# ADMIN_EMAIL below). Required for real SMTP sending.
EMAIL_HOST_USER=
# Gmail App Password for EMAIL_HOST_USER (not your normal Gmail password —
# create one at https://myaccount.google.com/apppasswords).
EMAIL_HOST_PASSWORD=
# Address that receives admin-facing notifications (e.g. support requests).
# Defaults to EMAIL_HOST_USER if left unset.
ADMIN_EMAIL=

# --- Scheduler ---
# Background job (core/scheduler.py) that emails meeting reminders every 5
# min; only runs under `python manage.py runserver`, never under pytest or a
# gunicorn worker. Set to 0 to force it off in any mode (e.g. extra replicas).
#RUN_SCHEDULER=1

# --- Rate limits (leave unset in production for the strict defaults below) ---
# Raise these on a dev machine so Playwright E2E runs (many logins/reloads
# from one IP) aren't throttled.
#THROTTLE_ANON=30/min
#THROTTLE_USER=300/min
#THROTTLE_LOGIN=5/min
#THROTTLE_REFRESH=30/min

# --- Documents ---
# Max upload size in bytes for student document uploads (default 10485760 = 10 MB).
DOCUMENT_MAX_UPLOAD_SIZE=10485760

# --- Cloudflare R2 storage (object storage for uploaded documents) ---
# Only used when DEPLOYMENT_MODE != desktop AND R2_ACCOUNT_ID is set; leave all
# four blank (or run desktop mode) to store documents on the local filesystem
# under media/ instead. Bucket must stay PRIVATE — files are only ever
# streamed through the permission-checked document endpoints.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
